   227	describe('memory hygiene (R8)', () => {
   228	  // Observable used here: `_storeSize()`, a documented non-enumerable debug
   229	  // hook on the limiter that reports how many keys the internal Map holds.
   230	  test('fully-expired one-off keys are removed from the internal store', () => {
   231	    const clock = makeClock(0);
   232	    const limiter = createRateLimiter({ limit: 2, windowMs: 100, now: clock.now });
   233	
   234	    for (let i = 0; i < 500; i += 1) {
   235	      limiter.check(`one-off-${i}`);
   236	    }
   237	    assert.equal(limiter._storeSize(), 500);
   238	
   239	    // Advance past the window so every one-off key's requests have expired,
   240	    // then trigger the module's sweep: any check() runs a global sweep once
   241	    // at least windowMs has elapsed since the previous sweep.
   242	    clock.advance(101);
   243	    limiter.check('fresh');
   244	
   245	    assert.equal(limiter._storeSize(), 1); // only 'fresh' remains
   246	
   247	    // _storeSize is intentionally non-enumerable (API surface stays
   248	    // exactly check/reset/stats).
   249	    assert.equal(Object.keys(limiter).includes('_storeSize'), false);
   250	  });
   251	
   252	  test('a key touched after its requests expired is pruned per-key too', () => {
   253	    const clock = makeClock(0);
   254	    const limiter = createRateLimiter({ limit: 1, windowMs: 100, now: clock.now });
   255	    limiter.check('a');
   256	    assert.equal(limiter._storeSize(), 1);
   257	    clock.set(100); // request at t=0 has just expired (trailing edge exclusive)
   258	    assert.deepEqual(limiter.stats('a'), { used: 0, remaining: 1, oldestMs: null });
   259	    assert.equal(limiter._storeSize(), 0);
   260	  });
   261	});
   262	
   263	describe('burst edge (R10)', () => {
   264	  test('exactly limit requests at one frozen timestamp are allowed; limit+1 is denied', () => {
   265	    const clock = makeClock(1000); // frozen: never advanced in this test
   266	    const limit = 5;
   267	    const limiter = createRateLimiter({ limit, windowMs: 250, now: clock.now });
   268	
   269	    for (let i = 1; i <= limit; i += 1) {
   270	      const result = limiter.check('burst');
   271	      assert.equal(result.allowed, true, `request #${i} must be allowed`);
   272	      assert.equal(result.remaining, limit - i);
   273	      assert.equal(result.retryAfterMs, 0);
   274	    }
   275	
   276	    const overflow = limiter.check('burst');
   277	    assert.equal(overflow.allowed, false, `request #${limit + 1} must be denied`);
   278	    assert.equal(overflow.remaining, 0);
   279	    // Oldest request happened at the frozen timestamp -> full window remains.
   280	    assert.equal(overflow.retryAfterMs, 250);
   281	  });
   282	});
   283	
   284	describe('window boundary edge (R11)', () => {
   285	  test('a request exactly windowMs after the first is allowed (trailing edge exclusive)', () => {
   286	    const clock = makeClock(0);
   287	    const limit = 3;
   288	    const windowMs = 100;
   289	    const limiter = createRateLimiter({ limit, windowMs, now: clock.now });
   290	
   291	    // t=0: fill to limit.
   292	    for (let i = 0; i < limit; i += 1) {
   293	      assert.equal(limiter.check('k').allowed, true);
   294	    }
   295	    assert.equal(limiter.check('k').allowed, false);
   296	
   297	    // t=windowMs-1: t=0 requests are still inside the window (0 > -1).
   298	    clock.set(windowMs - 1);
   299	    const stillDenied = limiter.check('k');
   300	    assert.equal(stillDenied.allowed, false);
   301	    assert.equal(stillDenied.retryAfterMs, 1);
   302	
   303	    // t=windowMs exactly: window is (0, 100], the t=0 requests have just
   304	    // expired, so a new request must be ALLOWED.
   305	    clock.set(windowMs);
   306	    const boundary = limiter.check('k');
   307	    assert.equal(boundary.allowed, true);
   308	    assert.equal(boundary.remaining, limit - 1); // all t=0 requests left together here
   309	  });
   310	});

