     1	// Sliding-window rate limiter (ESM, zero dependencies).
     2	//
     3	// Semantics
     4	// - A request made at time t is counted against the window (t - windowMs, t]:
     5	//   the trailing edge is EXCLUSIVE, so a request recorded at timestamp ts has
     6	//   expired once now() - windowMs >= ts. Requests expire individually as the
     7	//   window slides — there are no fixed buckets.
     8	// - All time reads go through the injectable `now` clock (defaulting to the
     9	//   system clock); nothing else in this module reads time directly.
    10	//
    11	// Memory hygiene (R8)
    12	// - Per key: whenever a key is touched (check/stats), its expired timestamps
    13	//   are pruned and the key is deleted from the store once empty.
    14	// - Globally: check() and stats() run a full sweep of the store at most once
    15	//   per windowMs (tracked via lastSweepAt), so one-off keys that are never
    16	//   touched again are still removed and the store cannot grow without bound.
    17	// - Observable: the returned limiter carries a NON-ENUMERABLE debug hook
    18	//   `_storeSize()` reporting the number of keys currently in the internal
    19	//   Map. It exists solely so tests can prove the hygiene property; it is a
    20	//   pure read (no sweep, no quota impact) and keeps the enumerable API
    21	//   surface at exactly { check, reset, stats }.
    22	
    23	/**
    24	 * Create a sliding-window rate limiter.
    25	 *
    26	 * @param {object} options
    27	 * @param {number} options.limit    Max requests allowed per key per window (> 0).
    28	 * @param {number} options.windowMs Window length in milliseconds (> 0).
    29	 * @param {() => number} [options.now] Injectable clock returning epoch ms;
    30	 *   the only source of time for the limiter. Defaults to the system clock.
    31	 * @returns {{
    32	 *   check(key: string): { allowed: boolean, remaining: number, retryAfterMs: number },
    33	 *   reset(key: string): void,
    34	 *   stats(key: string): { used: number, remaining: number, oldestMs: number | null },
    35	 * }}
    36	 * @throws {RangeError} At factory time when limit or windowMs is not a positive number.
    37	 */
    38	export function createRateLimiter({ limit, windowMs, now = Date.now } = {}) {
    39	  if (!Number.isFinite(limit) || limit <= 0) {
    40	    throw new RangeError(`limit must be a positive number, got ${limit}`);
    41	  }
    42	  if (!Number.isFinite(windowMs) || windowMs <= 0) {
    43	    throw new RangeError(`windowMs must be a positive number, got ${windowMs}`);
    44	  }
    45	
    46	  /** @type {Map<string, number[]>} key -> ascending in-window request timestamps.
    47	   * A Map (not a plain object) makes hostile keys like "__proto__" or
    48	   * "constructor" structurally safe. */
    49	  const store = new Map();
    50	  let lastSweepAt = now();
    51	
    52	  /**
    53	   * Drop this key's expired timestamps (ts <= t - windowMs) and delete the
    54	   * key entirely once empty. Returns the key's live in-window timestamps.
    55	   */
    56	  function prune(key, t) {
    57	    const timestamps = store.get(key);
    58	    if (timestamps === undefined) return [];
    59	    const cutoff = t - windowMs;
    60	    let expired = 0;
    61	    while (expired < timestamps.length && timestamps[expired] <= cutoff) expired += 1;
    62	    if (expired > 0) timestamps.splice(0, expired);
    63	    if (timestamps.length === 0) {
    64	      store.delete(key);
    65	      return [];
    66	    }
    67	    return timestamps;
    68	  }
    69	
    70	  /** Full-store sweep, rate-limited to at most once per windowMs. */
    71	  function sweepIfDue(t) {
    72	    if (t - lastSweepAt < windowMs) return;
    73	    lastSweepAt = t;
    74	    for (const key of [...store.keys()]) prune(key, t);
    75	  }
    76	
    77	  function check(key) {
    78	    const t = now();
    79	    sweepIfDue(t);
    80	    const timestamps = prune(key, t);
    81	    if (timestamps.length >= limit) {
    82	      // Oldest in-window request (ascending order -> index 0) expires exactly
    83	      // at timestamps[0] + windowMs.
    84	      return { allowed: false, remaining: 0, retryAfterMs: timestamps[0] + windowMs - t };
    85	    }
    86	    const list = store.get(key) ?? [];
    87	    list.push(t);
    88	    store.set(key, list);
    89	    return { allowed: true, remaining: limit - list.length, retryAfterMs: 0 };
    90	  }
    91	
    92	  function reset(key) {
    93	    store.delete(key);
    94	  }
    95	
    96	  function stats(key) {
    97	    const t = now();
    98	    sweepIfDue(t);
    99	    const timestamps = prune(key, t);
   100	    const used = timestamps.length;
   101	    return {
   102	      used,
   103	      remaining: Math.max(0, limit - used),
   104	      // Age in ms of the oldest in-window request; null when none in window.
   105	      oldestMs: used === 0 ? null : t - timestamps[0],
   106	    };
   107	  }
   108	
   109	  const limiter = { check, reset, stats };
   110	  // Documented debug hook for memory-hygiene tests (see header comment).
   111	  Object.defineProperty(limiter, '_storeSize', {
   112	    value: () => store.size,
   113	    enumerable: false,
   114	  });
   115	  return limiter;
   116	}

