    10	/** Manual, fully deterministic clock for injection via the `now` option. */
    11	function makeClock(start = 0) {
    12	  let t = start;
    13	  return {
    14	    now: () => t,
    15	    advance(ms) {
    16	      t += ms;
    17	    },
    18	    set(ms) {
    19	      t = ms;
    20	    },
    21	  };
