     1	// Sliding-window rate limiter (ESM, zero dependencies).
     2	//
     3	// Semantics
     4	// - A request made at time t is counted against the window (t - windowMs, t]:
     5	//   the trailing edge is EXCLUSIVE, so a request recorded at timestamp ts has
     6	//   expired once now() - windowMs >= ts. Requests expire individually as the
     7	//   window slides — there are no fixed buckets.
     8	// - All time reads go through the injectable `now` clock (defaulting to the
     9	//   system clock); nothing else in this module reads time directly.
    10	//
    11	// Memory hygiene (R8)
    12	// - Per key: whenever a key is touched (check/stats), its expired timestamps
    13	//   are pruned and the key is deleted from the store once empty.
    14	// - Globally: check() and stats() run a full sweep of the store at most once
    15	//   per windowMs (tracked via lastSweepAt), so one-off keys that are never
    16	//   touched again are still removed and the store cannot grow without bound.
    17	// - Observable: the returned limiter carries a NON-ENUMERABLE debug hook
    18	//   `_storeSize()` reporting the number of keys currently in the internal
    19	//   Map. It exists solely so tests can prove the hygiene property; it is a
    20	//   pure read (no sweep, no quota impact) and keeps the enumerable API
    21	//   surface at exactly { check, reset, stats }.
    22	
    23	/**
    24	 * Create a sliding-window rate limiter.
    25	 *
    26	 * @param {object} options
    27	 * @param {number} options.limit    Max requests allowed per key per window
    28	 *   (positive integer — it is a request count).
    29	 * @param {number} options.windowMs Window length in milliseconds (> 0;
    30	 *   fractional ms are semantically valid time).
    31	 * @param {() => number} [options.now] Injectable clock returning epoch ms;
    32	 *   the only source of time for the limiter. Defaults to the system clock.
    33	 * @returns {{
    34	 *   check(key: string): { allowed: boolean, remaining: number, retryAfterMs: number },
    35	 *   reset(key: string): void,
    36	 *   stats(key: string): { used: number, remaining: number, oldestMs: number | null },
    37	 * }}
    38	 * @throws {RangeError} At factory time when limit is not a positive integer
    39	 *   or windowMs is not a positive finite number.
    40	 */
    41	export function createRateLimiter({ limit, windowMs, now = Date.now } = {}) {
    42	  if (!Number.isInteger(limit) || limit <= 0) {
    43	    throw new RangeError(`limit must be a positive integer, got ${limit}`);
    44	  }
    45	  if (!Number.isFinite(windowMs) || windowMs <= 0) {
    46	    throw new RangeError(`windowMs must be a positive number, got ${windowMs}`);
    47	  }
    48	
    49	  /** @type {Map<string, number[]>} key -> ascending in-window request timestamps.
    50	   * A Map (not a plain object) makes hostile keys like "__proto__" or
    51	   * "constructor" structurally safe. */
    52	  const store = new Map();
    53	  let lastSweepAt = now();
    54	
    55	  /**
    56	   * Drop this key's expired timestamps (ts <= t - windowMs) and delete the
    57	   * key entirely once empty. Returns the key's live in-window timestamps.
    58	   */
    59	  function prune(key, t) {
    60	    const timestamps = store.get(key);
    61	    if (timestamps === undefined) return [];
    62	    const cutoff = t - windowMs;
    63	    let expired = 0;
    64	    while (expired < timestamps.length && timestamps[expired] <= cutoff) expired += 1;
    65	    if (expired > 0) timestamps.splice(0, expired);
    66	    if (timestamps.length === 0) {
    67	      store.delete(key);
    68	      return [];
    69	    }
    70	    return timestamps;
    71	  }
    72	
    73	  /** Full-store sweep, rate-limited to at most once per windowMs. */
    74	  function sweepIfDue(t) {
    75	    if (t - lastSweepAt < windowMs) return;
    76	    lastSweepAt = t;
    77	    for (const key of [...store.keys()]) prune(key, t);
    78	  }
    79	
    80	  function check(key) {
    81	    const t = now();
    82	    sweepIfDue(t);
    83	    const timestamps = prune(key, t);
    84	    if (timestamps.length >= limit) {
    85	      // Oldest in-window request (ascending order -> index 0) expires exactly
    86	      // at timestamps[0] + windowMs.
    87	      return { allowed: false, remaining: 0, retryAfterMs: timestamps[0] + windowMs - t };
    88	    }
    89	    const list = store.get(key) ?? [];
    90	    list.push(t);
    91	    store.set(key, list);
    92	    return { allowed: true, remaining: limit - list.length, retryAfterMs: 0 };
    93	  }
    94	
    95	  function reset(key) {
    96	    store.delete(key);
    97	  }
    98	
    99	  function stats(key) {
   100	    const t = now();
   101	    sweepIfDue(t);
   102	    const timestamps = prune(key, t);
   103	    const used = timestamps.length;
   104	    return {
   105	      used,
   106	      remaining: Math.max(0, limit - used),
   107	      // Age in ms of the oldest in-window request; null when none in window.
   108	      oldestMs: used === 0 ? null : t - timestamps[0],
   109	    };
   110	  }
   111	
   112	  const limiter = { check, reset, stats };
   113	  // Documented debug hook for memory-hygiene tests (see header comment).
   114	  Object.defineProperty(limiter, '_storeSize', {
   115	    value: () => store.size,
   116	    enumerable: false,
   117	  });
   118	  return limiter;
   119	}

