   314	    const stillDenied = limiter.check('k');
   315	    assert.equal(stillDenied.allowed, false);
   316	    assert.equal(stillDenied.retryAfterMs, 1);
   317	
   318	    // t=windowMs exactly: window is (0, 100], the t=0 requests have just
   319	    // expired, so a new request must be ALLOWED.
   320	    clock.set(windowMs);
   321	    const boundary = limiter.check('k');
   322	    assert.equal(boundary.allowed, true);
   323	    assert.equal(boundary.remaining, limit - 1); // all t=0 requests left together here
   324	  });
   325	});

