    22	}
    23	
    24	/**
    25	 * Tokenize CSV text into records (RFC 4180 style: quoted fields may contain
    26	 * commas, escaped quotes `""`, and newlines). Handles LF, CRLF, and lone CR
    27	 * line endings. Blank lines are skipped.
    28	 *
    29	 * Returns [{ fields: string[], line: number }] where `line` is the 1-based
    30	 * physical line number in the original text at which the record starts.
    31	 */
    32	function tokenize(text) {
    33	  const records = [];
    34	  let fields = [];
    35	  let field = '';
    36	  let inQuotes = false;
    37	  let line = 1;
    38	  let recordLine = 1;
    39	  let recordStarted = false;
    40	
    41	  const endField = () => {
    42	    fields.push(field);
    43	    field = '';
    44	  };
    45	  const endRecord = () => {
    46	    endField();
    47	    const isBlankLine = fields.length === 1 && fields[0].trim() === '';
    48	    if (!isBlankLine) records.push({ fields, line: recordLine });
    49	    fields = [];
    50	    recordStarted = false;
    51	  };
    52	
    53	  for (let i = 0; i < text.length; i++) {
    54	    const c = text[i];
    55	    if (!recordStarted) {
    56	      recordLine = line;
    57	      recordStarted = true;
    58	    }
    59	    if (inQuotes) {
    60	      if (c === '"') {
    61	        if (text[i + 1] === '"') {
    62	          field += '"';
    63	          i++;
    64	        } else {
    65	          inQuotes = false;
    66	        }
    67	      } else {
    68	        if (c === '\n') line++;
    69	        field += c;
    70	      }
    71	    } else if (c === '"') {
    72	      inQuotes = true;
    73	    } else if (c === ',') {
    74	      endField();
    75	    } else if (c === '\r') {
    76	      if (text[i + 1] !== '\n') {
    77	        // Lone CR acts as a line ending; CRLF is handled by the '\n' branch.
    78	        line++;
    79	        endRecord();
    80	      }
    81	    } else if (c === '\n') {
    82	      line++;
    83	      endRecord();
    84	    } else {
    85	      field += c;
    86	    }
    87	  }
    88	  if (recordStarted) endRecord();
    89	  return records;
    90	}
    91	
    92	function validateHeader(headerFields) {
    93	  const normalized = headerFields.map((f) => f.trim().toLowerCase());
    94	  const seen = new Set();
    95	  const unexpected = [];
    96	  for (const col of normalized) {
    97	    if (!REQUIRED_COLUMNS.includes(col) || seen.has(col)) unexpected.push(col);
    98	    seen.add(col);
    99	  }
   100	  const missing = REQUIRED_COLUMNS.filter((c) => !seen.has(c));
   101	  if (missing.length > 0 || unexpected.length > 0) {
   102	    const parts = [];
   103	    if (missing.length > 0) parts.push(`missing required column(s): ${missing.join(', ')}`);
   104	    if (unexpected.length > 0) parts.push(`unexpected column(s): ${unexpected.join(', ')}`);
   105	    throw new HeaderError(`invalid header: ${parts.join('; ')}`, { missing, unexpected });
   106	  }
   107	  return {
   108	    name: normalized.indexOf('name'),
   109	    email: normalized.indexOf('email'),
   110	    phone: normalized.indexOf('phone'),
   111	  };
   112	}
   113	
   114	// Strip spaces, dashes, and parentheses; the result must be digits only.
   115	function normalizePhone(raw) {
   116	  const digits = raw.replace(/[\s\-()]/g, '');
   117	  return /^\d+$/.test(digits) ? digits : null;
   118	}
   119	
   120	/**
   121	 * Parse a contacts CSV (header: name,email,phone in any order).
   122	 *
   123	 * @param {string} csvText - Full CSV file contents (BOM/CRLF tolerated).
   124	 * @returns {{ contacts: Array<{name: string, email: string, phone: string}>,
   125	 *             errors: Array<{line: number, reason: string}> }}
   126	 *   `errors[].line` is the 1-based line number in the original file
   127	 *   (the header is line 1).
   128	 * @throws {HeaderError} if the header is missing or not exactly {name,email,phone}.
   129	 */
   130	export function parseContacts(csvText) {
   131	  const records = tokenize(stripBom(String(csvText)));
   132	  if (records.length === 0) {
   133	    throw new HeaderError(
   134	      `invalid header: missing required column(s): ${REQUIRED_COLUMNS.join(', ')}`,
   135	      { missing: [...REQUIRED_COLUMNS] },
   136	    );
   137	  }
   138	
   139	  const columnIndex = validateHeader(records[0].fields);
   140	  const contacts = [];
   141	  const errors = [];
   142	  const seenEmails = new Set();
   143	
   144	  for (const { fields, line } of records.slice(1)) {
   145	    if (fields.length !== REQUIRED_COLUMNS.length) {
   146	      errors.push({
   147	        line,
   148	        reason: `expected ${REQUIRED_COLUMNS.length} fields, got ${fields.length}`,
   149	      });
   150	      continue;
   151	    }
   152	
   153	    const name = fields[columnIndex.name].trim();
   154	    const email = fields[columnIndex.email].trim();
   155	    const phone = normalizePhone(fields[columnIndex.phone].trim());
   156	
   157	    let reason = null;
   158	    if (name === '') reason = 'empty name';
   159	    else if (!EMAIL_RE.test(email)) reason = 'invalid email';
   160	    else if (phone === null) reason = 'invalid phone';
   161	    else if (seenEmails.has(email.toLowerCase())) reason = 'duplicate email';
   162	
   163	    if (reason !== null) {
   164	      errors.push({ line, reason });
   165	      continue;
   166	    }
   167	
   168	    seenEmails.add(email.toLowerCase());
   169	    contacts.push({ name, email, phone });
   170	  }
   171	
   172	  return { contacts, errors };
   173	}

