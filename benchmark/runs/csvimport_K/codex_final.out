   243	    const res = runCli(input, output);
   244	    assert.equal(res.status, 0);
   245	    assert.equal(res.stdout, 'imported 1/1 rows\n');
   246	    const raw = readFileSync(output, 'utf8');
   247	    assert.ok(raw.endsWith('\n'), 'output must end with a trailing newline');
   248	    assert.deepEqual(JSON.parse(raw), {
   249	      contacts: [{ name: 'Kim', email: 'kim@example.com', phone: '01012345678' }],
   250	    });
   251	  });
   252	
   253	  test('R7/R5: some rows rejected -> exit 1, errors on stderr as "line <n>: <reason>"', () => {
