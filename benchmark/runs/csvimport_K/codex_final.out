import { mkdtempSync, writeFileSync, readFileSync, rmSync } from 'node:fs';
import { tmpdir } from 'node:os';
import { join } from 'node:path';
import { spawnSync } from 'node:child_process';

const dir = mkdtempSync(join(tmpdir(), 'csvimport-final-'));
try {
  const input = join(dir, 'contacts.csv');
  const output = join(dir, 'contacts.json');
  writeFileSync(
    input,
    '\\ufeffphone,name,email\\r\\n' +
      '\"(010) 111-2222\",\"Kim, Minsu\",kim@example.com\\r\\n' +
      '0103334444,\"Lee \"\"L\"\"\",LEE@example.com\\r\\n' +
      '0109998888,Bad,bad-email\\r\\n' +
      '0107776666,Dup,KIM@example.com\\r\\n',
    'utf8',
  );
  const res = spawnSync(process.execPath, ['src/importCsv.js', input, output], {
    encoding: 'utf8',
  });
  console.log(JSON.stringify({
    status: res.status,
    stdout: res.stdout,
    stderr: res.stderr,
    output: readFileSync(output, 'utf8'),
  }, null, 2));
} finally {
  rmSync(dir, { recursive: true, force: true });
}
