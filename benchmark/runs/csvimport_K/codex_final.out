    53	  for (let i = 0; i < text.length; i++) {
    54	    const c = text[i];
    55	    if (!recordStarted) {
    56	      recordLine = line;
    57	      recordStarted = true;
    58	    }
    59	    if (inQuotes) {
    60	      if (c === '"') {
    61	        if (text[i + 1] === '"') {
    62	          field += '"';
    63	          i++;
    64	        } else {
    65	          inQuotes = false;
    66	        }
    67	      } else {
    68	        if (c === '\n') line++;
    69	        field += c;
    70	      }
    71	    } else if (c === '"') {
    72	      inQuotes = true;
    73	    } else if (c === ',') {
    74	      endField();
    75	    } else if (c === '\r') {
    76	      if (text[i + 1] !== '\n') {
