exec
/bin/bash -lc "node --input-type=module <<'NODE'
import { mkdtempSync, writeFileSync, readFileSync, rmSync } from 'node:fs';
import { tmpdir } from 'node:os';
import { join } from 'node:path';
import { spawnSync } from 'node:child_process';

const dir = mkdtempSync(join(tmpdir(), 'csvimport-final-edge-'));
try {
  const headerOnlyIn = join(dir, 'empty.csv');
  const headerOnlyOut = join(dir, 'empty.json');
  writeFileSync(headerOnlyIn, 'name,email,phone\\n');
  const headerOnly = spawnSync(process.execPath, ['src/importCsv.js', headerOnlyIn, headerOnlyOut], { encoding: 'utf8' });

  const badHeaderIn = join(dir, 'bad.csv');
  const badHeaderOut = join(dir, 'bad.json');
  writeFileSync(badHeaderIn, 'name,email\\nA,a@example.com\\n');
  const badHeader = spawnSync(process.execPath, ['src/importCsv.js', badHeaderIn, badHeaderOut], { encoding: 'utf8' });

  const unwritableIn = join(dir, 'valid.csv');
  writeFileSync(unwritableIn, 'name,email,phone\\nA,a@example.com,010-1111\\n');
  const unwritable = spawnSync(process.execPath, ['src/importCsv.js', unwritableIn, join(dir, 'missing-dir', 'out.json')], { encoding: 'utf8' });

  console.log(JSON.stringify({
    headerOnly: {
      status: headerOnly.status,
      stdout: headerOnly.stdout,
      stderr: headerOnly.stderr,
      output: readFileSync(headerOnlyOut, 'utf8'),
    },
    badHeader: {
      status: badHeader.status,
      stdout: badHeader.stdout,
      stderr: badHeader.stderr,
    },
    unwritable: {
      status: unwritable.status,
      stdout: unwritable.stdout,
      stderrPrefix: unwritable.stderr.split('\\n')[0],
    },
  }, null, 2));
} finally {
  rmSync(dir, { recursive: true, force: true });
}
