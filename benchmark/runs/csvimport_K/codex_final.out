    92	function validateHeader(headerFields) {
    93	  const normalized = headerFields.map((f) => f.trim().toLowerCase());
    94	  const seen = new Set();
    95	  const unexpected = [];
    96	  for (const col of normalized) {
    97	    if (!REQUIRED_COLUMNS.includes(col) || seen.has(col)) unexpected.push(col);
    98	    seen.add(col);
    99	  }
   100	  const missing = REQUIRED_COLUMNS.filter((c) => !seen.has(c));
   101	  if (missing.length > 0 || unexpected.length > 0) {
   102	    const parts = [];
   103	    if (missing.length > 0) parts.push(`missing required column(s): ${missing.join(', ')}`);
   104	    if (unexpected.length > 0) parts.push(`unexpected column(s): ${unexpected.join(', ')}`);
   105	    throw new HeaderError(`invalid header: ${parts.join('; ')}`, { missing, unexpected });
