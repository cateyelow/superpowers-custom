     1	#!/usr/bin/env node
     2	// Thin CLI wrapper around parser.js: argv handling, file I/O, atomic write,
     3	// error/summary reporting, and exit codes. All parsing logic lives in parser.js.
     4	
     5	import { readFileSync, writeFileSync, renameSync, rmSync } from 'node:fs';
     6	import { dirname, basename, join } from 'node:path';
     7	import process from 'node:process';
     8	
     9	import { parseContacts, HeaderError } from './parser.js';
    10	
    11	const USAGE = `Usage: node src/importCsv.js <input.csv> <output.json>
    12	
    13	Imports a contacts CSV (header: name,email,phone in any order) into a
    14	normalized JSON file: { "contacts": [{ "name", "email", "phone" }] }.
    15	
    16	Invalid rows are reported to stderr as "line <n>: <reason>" and skipped.
    17	A one-line summary "imported <k>/<total> rows" is printed to stdout.
    18	
    19	Options:
    20	  -h, --help    Show this help and exit.
    21	
    22	Exit codes:
    23	  0  all rows imported
    24	  1  completed, but some rows were rejected
    25	  2  fatal error (unreadable input, bad header, unwritable output)`;
    26	
    27	function writeFileAtomic(outputPath, data) {
    28	  const tempPath = join(
    29	    dirname(outputPath),
    30	    `.${basename(outputPath)}.${process.pid}.${Date.now()}.tmp`,
    31	  );
    32	  try {
    33	    writeFileSync(tempPath, data);
    34	    renameSync(tempPath, outputPath);
    35	  } catch (err) {
    36	    rmSync(tempPath, { force: true });
    37	    throw err;
    38	  }
    39	}
    40	
    41	function main(argv) {
    42	  const args = argv.slice(2);
    43	  if (args.includes('--help') || args.includes('-h')) {
    44	    console.log(USAGE);
    45	    return 0;
    46	  }
    47	  if (args.length !== 2) {
    48	    console.error(USAGE);
    49	    return 2;
    50	  }
    51	  const [inputPath, outputPath] = args;
    52	
    53	  let csvText;
    54	  try {
    55	    csvText = readFileSync(inputPath, 'utf8');
    56	  } catch (err) {
    57	    console.error(`error: cannot read ${inputPath}: ${err.message}`);
    58	    return 2;
    59	  }
    60	
    61	  let contacts;
    62	  let errors;
    63	  try {
    64	    ({ contacts, errors } = parseContacts(csvText));
    65	  } catch (err) {
    66	    if (err instanceof HeaderError) {
    67	      console.error(`error: ${err.message}`);
    68	      return 2;
    69	    }
    70	    throw err;
    71	  }
    72	
    73	  for (const { line, reason } of errors) {
    74	    console.error(`line ${line}: ${reason}`);
    75	  }
    76	
    77	  const json = `${JSON.stringify({ contacts }, null, 2)}\n`;
    78	  try {
    79	    writeFileAtomic(outputPath, json);
    80	  } catch (err) {
    81	    console.error(`error: cannot write ${outputPath}: ${err.message}`);
    82	    return 2;
    83	  }
    84	
    85	  const total = contacts.length + errors.length;
    86	  console.log(`imported ${contacts.length}/${total} rows`);
    87	  return errors.length > 0 ? 1 : 0;
    88	}
    89	
    90	process.exit(main(process.argv));

