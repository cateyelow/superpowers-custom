    18	 * @returns {{
    19	 *   check(key: string): { allowed: boolean, remaining: number, retryAfterMs: number },
    20	 *   reset(key: string): void,
    21	 *   stats(key: string): { used: number, remaining: number, oldestMs: number | null },
    22	 *   _storeSize(): number,
    23	 * }}
    24	 * @throws {RangeError} when `limit` is not a positive integer or `windowMs`
    25	 *   is not a positive finite number.
    26	 */
    27	export function createRateLimiter({ limit, windowMs, now = Date.now } = {}) {
    28	  if (!Number.isInteger(limit) || limit <= 0) {
    29	    throw new RangeError(`limit must be a positive integer, got ${limit}`);
    30	  }
    31	  if (typeof windowMs !== 'number' || !Number.isFinite(windowMs) || windowMs <= 0) {
    32	    throw new RangeError(`windowMs must be a positive finite number, got ${windowMs}`);
    33	  }
    34	
    35	  /** @type {Map<string, number[]>} key -> ascending in-window request timestamps */
    36	  const store = new Map();
    37	
    38	  // Amortized sweep bookkeeping: at most one full-store sweep per windowMs,
    39	  // so keys that were hit once and never again ("one-off" keys) are evicted
    40	  // within one window of any later activity. -Infinity makes the first call
    41	  // sweep a trivially empty store and initialize the timestamp.
    42	  let lastSweepAt = -Infinity;
    43	
    44	  /**
    45	   * Drop expired timestamps (ts <= t - windowMs) from a key's list and evict
    46	   * the key entirely when nothing remains. Returns the live timestamp list.
    47	   */
    48	  function prune(key, t) {
    49	    const timestamps = store.get(key);
    50	    if (timestamps === undefined) return undefined;
    51	    const cutoff = t - windowMs;
    52	    let firstLive = 0;
    53	    while (firstLive < timestamps.length && timestamps[firstLive] <= cutoff) {
    54	      firstLive += 1;
    55	    }
    56	    if (firstLive === timestamps.length) {
    57	      store.delete(key);
    58	      return undefined;
    59	    }
    60	    if (firstLive > 0) timestamps.splice(0, firstLive);
    61	    return timestamps;
    62	  }
    63	
    64	  /** Sweep every key at most once per windowMs (memory hygiene, R8). */
    65	  function maybeSweep(t) {
    66	    if (t - lastSweepAt < windowMs) return;
    67	    lastSweepAt = t;
    68	    for (const key of store.keys()) prune(key, t);
    69	  }
    70	
    71	  return {
    72	    /**
    73	     * Consume one slot for `key` if the window has capacity.
    74	     * Never throws for string keys.
    75	     */
    76	    check(key) {
    77	      const t = now();
    78	      maybeSweep(t);
    79	      const timestamps = prune(key, t);
    80	
    81	      if (timestamps === undefined) {
    82	        store.set(key, [t]);
    83	        return { allowed: true, remaining: limit - 1, retryAfterMs: 0 };
    84	      }
    85	      if (timestamps.length < limit) {
    86	        timestamps.push(t);
    87	        return { allowed: true, remaining: limit - timestamps.length, retryAfterMs: 0 };
    88	      }
    89	      // Denied: the oldest in-window request expires at oldest + windowMs.
    90	      return {
    91	        allowed: false,
    92	        remaining: 0,
    93	        retryAfterMs: timestamps[0] + windowMs - t,
    94	      };
    95	    },
    96	
    97	    /** Clear all state for `key` only; other keys are untouched. */
    98	    reset(key) {
    99	      store.delete(key);
   100	    },
   101	
   102	    /**
   103	     * Report usage for `key` without consuming quota.
   104	     * `oldestMs` is the age in ms of the oldest in-window request
   105	     * (now - its timestamp), or null when the key has no live requests.
   106	     */
   107	    stats(key) {
   108	      const t = now();
   109	      const timestamps = prune(key, t);
   110	      if (timestamps === undefined) {
   111	        return { used: 0, remaining: limit, oldestMs: null };
   112	      }
   113	      return {
   114	        used: timestamps.length,
   115	        remaining: Math.max(0, limit - timestamps.length),
   116	        oldestMs: t - timestamps[0],
   117	      };
   118	    },
   119	
   120	    /**
   121	     * Introspection hook: number of keys currently held in the internal
   122	     * store. Exists SOLELY so tests can prove R8 (memory hygiene — fully
   123	     * expired keys are evicted); it is not part of the limiter's public
   124	     * rate-limiting contract.
   125	     */
   126	    _storeSize() {
   127	      return store.size;
   128	    },
   129	  };
   130	}

