   362	  var NICKNAME_PATTERN = /^[A-Za-z0-9가-힣]{2,12}$/;
   363	
   364	  var passwordRules = [
   365	    { id: 'rule-length', test: function (v) { return v.length >= 10; } },
   366	    { id: 'rule-letter', test: function (v) { return /[A-Za-z]/.test(v); } },
   367	    { id: 'rule-digit',  test: function (v) { return /[0-9]/.test(v); } },
   368	    { id: 'rule-symbol', test: function (v) { return /[^A-Za-z0-9\s]/.test(v); } }
