const { chromium } = require('playwright');
const fileUrl = 'file:///home/ubuntu/Github/superpowers-custom/benchmark/runs/signupform_K/src/signup.html';
(async () => {
  const browser = await chromium.launch({ headless: true, executablePath: '/snap/bin/chromium', args: ['--no-sandbox'] });
  const page = await browser.newPage({ viewport: { width: 375, height: 900 } });
  await page.goto(fileUrl, { waitUntil: 'load' });
  const initialTabs = [];
  for (let i = 0; i < 5; i++) {
    await page.keyboard.press('Tab');
    initialTabs.push(await page.evaluate(() => document.activeElement.id));
  }
  await page.locator('#email').fill('ada@example.com');
  await page.locator('#password').fill('abc123"'!@#$'"');
  await page.locator('#password-confirm').fill('abc123"'!@#$'"');
  await page.locator('#nickname').fill('테스트12');
  await page.locator('#terms').focus();
  await page.keyboard.press('Space');
  const checkedBySpace = await page.locator('#terms').isChecked();
  await page.keyboard.press('Tab');
  const afterTermsTab = await page.evaluate(() => document.activeElement.id);
  await page.keyboard.press('Enter');
  await page.waitForTimeout(100);
  const afterEnter = await page.evaluate(() => ({ activeId: document.activeElement.id, successHidden: document.getElementById('success-panel').hidden }));
  await browser.close();
  console.log(JSON.stringify({ initialTabs, checkedBySpace, afterTermsTab, afterEnter }, null, 2));
})().catch(err => { console.error(err); process.exit(1); });
