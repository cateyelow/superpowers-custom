const { chromium } = require('playwright');
const fileUrl = 'file:///home/ubuntu/Github/superpowers-custom/benchmark/runs/signupform_K/src/signup.html';
(async () => {
  const browser = await chromium.launch({ headless: true, executablePath: '/snap/bin/chromium', args: ['--no-sandbox'] });
  const page = await browser.newPage({ viewport: { width: 375, height: 900 } });
  const messages = [];
  page.on('console', msg => messages.push({ type: msg.type(), text: msg.text() }));
  page.on('pageerror', err => messages.push({ type: 'pageerror', text: err.message }));
  await page.goto(fileUrl, { waitUntil: 'load' });
  await page.waitForTimeout(200);

  const initial = await page.evaluate(() => ({
    url: location.href,
    scrollWidth: document.documentElement.scrollWidth,
    innerWidth: window.innerWidth,
    heights: {
      email: document.getElementById('email').getBoundingClientRect().height,
      password: document.getElementById('password').getBoundingClientRect().height,
      confirm: document.getElementById('password-confirm').getBoundingClientRect().height,
      nickname: document.getElementById('nickname').getBoundingClientRect().height,
      terms: document.getElementById('terms').getBoundingClientRect().height,
      submit: document.getElementById('submit-button').getBoundingClientRect().height,
    },
    submitDisabled: document.getElementById('submit-button').disabled,
    passwordChecklistItems: Array.from(document.querySelectorAll('#password-rules li')).map(li => li.textContent.trim().replace(/\\s+/g, ' ')),
    labels: Array.from(document.querySelectorAll('input')).map(input => ({ id: input.id, labelFor: "'!!document.querySelector(`label[for="${input.id}"]`) })),
    describedErrors: ['"'email','password','password-confirm','nickname'].map(id => {
      const input = document.getElementById(id);
      const described = (input.getAttribute('aria-describedby') || '').split(/\\s+/).filter(Boolean);
      return { id, described, alertIds: described.filter(d => document.getElementById(d)?.getAttribute('role') === 'alert') };
    })
  }));

  await page.locator('#email').fill('bad');
  const emailBeforeBlur = await page.locator('#email-error').textContent();
  await page.locator('#password').focus();
  const emailAfterBlur = await page.locator('#email-error').textContent();

  await page.locator('#email').fill('ada@example.com');
  await page.locator('#password').fill('abc123"'!@#$'"');
  const checklistAfterPassword = await page.evaluate(() => Array.from(document.querySelectorAll('#password-rules li')).map(li => li.getAttribute('data-met')));
  await page.locator('#password-confirm').fill('wrong');
  await page.locator('#nickname').focus();
  const confirmAfterBlur = await page.locator('#password-confirm-error').textContent();
  await page.locator('#password-confirm').fill('abc123"'!@#$'"');
  const confirmAfterMatch = await page.locator('#password-confirm-error').textContent();
  await page.locator('#nickname').fill('테스트12');
  await page.locator('#nickname').blur();
  await page.locator('#terms').check();
  const enabledBeforeSubmit = await page.locator('#submit-button').isEnabled();
  await page.locator('#submit-button').press('Enter');
  await page.waitForTimeout(100);
  const success = await page.evaluate(() => ({
    panelHidden: document.getElementById('success-panel').hidden,
    activeId: document.activeElement.id,
    emailText: document.getElementById('success-email').textContent,
    nickText: document.getElementById('success-nickname').textContent,
    bodyIncludesPassword: document.body.textContent.includes('abc123"'!@#$'"')
  }));

  await browser.close();
  console.log(JSON.stringify({
    consoleErrors: messages.filter(m => m.type === 'error' || m.type === 'pageerror'),
    initial,
    emailBeforeBlur,
    emailAfterBlur,
    checklistAfterPassword,
    confirmAfterBlur,
    confirmAfterMatch,
    enabledBeforeSubmit,
    success
  }, null, 2));
})().catch(err => { console.error(err); process.exit(1); });
