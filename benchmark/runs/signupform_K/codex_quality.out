   280	            <span class="tick" aria-hidden="true">&bull;</span>
   281	            <span>At least one letter</span>
   282	            <span class="rule-state visually-hidden">(rule not met)</span>
   283	          </li>
   284	          <li id="rule-digit" data-met="false">
   285	            <span class="tick" aria-hidden="true">&bull;</span>
   286	            <span>At least one number</span>
   287	            <span class="rule-state visually-hidden">(rule not met)</span>
   288	          </li>
   289	          <li id="rule-symbol" data-met="false">
   290	            <span class="tick" aria-hidden="true">&bull;</span>
   291	            <span>At least one symbol</span>
   292	            <span class="rule-state visually-hidden">(rule not met)</span>
   293	          </li>
   294	        </ul>
   295	      </div>
   296	    </div>
   297	
   298	    <div class="field">
   299	      <label for="password-confirm">Confirm password</label>
   300	      <input class="control" id="password-confirm" name="password-confirm"
   301	             type="password" autocomplete="new-password"
   302	             aria-describedby="password-confirm-error">
   303	      <p class="error" id="password-confirm-error" role="alert"></p>
   304	    </div>
   305	
   306	    <div class="field">
   307	      <label for="nickname">Nickname</label>
   308	      <input class="control" id="nickname" name="nickname" type="text"
   309	             autocomplete="nickname" maxlength="12"
   310	             aria-describedby="nickname-hint nickname-error">
   311	      <p class="hint" id="nickname-hint">2&ndash;12 characters &mdash; letters, numbers, and Korean only.</p>
   312	      <p class="error" id="nickname-error" role="alert"></p>
   313	    </div>
   314	
   315	    <div class="terms">
   316	      <input type="checkbox" id="terms" name="terms">
   317	      <label for="terms">I agree to the Terms of Service (required)</label>
   318	    </div>
   319	
   320	    <button type="submit" id="submit-button" disabled>Create account</button>
   321	  </form>
   322	
   323	  <section class="success" id="success-panel" tabindex="-1" hidden
   324	           aria-labelledby="success-title">
   325	    <h2 id="success-title">Account created</h2>
   326	    <p>Welcome! Here is what you signed up with:</p>
   327	    <dl>
   328	      <div>
   329	        <dt>Email</dt>
   330	        <dd id="success-email"></dd>
   331	      </div>
   332	      <div>
   333	        <dt>Nickname</dt>
   334	        <dd id="success-nickname"></dd>
   335	      </div>
   336	    </dl>
   337	  </section>
   338	</main>
   339	
   340	<script>
   341	(function () {
   342	  'use strict';
   343	
   344	  var form = document.getElementById('signup-form');
   345	  var emailInput = document.getElementById('email');
   346	  var passwordInput = document.getElementById('password');
   347	  var confirmInput = document.getElementById('password-confirm');
   348	  var nicknameInput = document.getElementById('nickname');
   349	  var termsInput = document.getElementById('terms');
   350	  var submitButton = document.getElementById('submit-button');
   351	
   352	  var emailError = document.getElementById('email-error');
   353	  var passwordError = document.getElementById('password-error');
   354	  var confirmError = document.getElementById('password-confirm-error');
   355	  var nicknameError = document.getElementById('nickname-error');
   356	
   357	  var successPanel = document.getElementById('success-panel');
   358	  var successEmail = document.getElementById('success-email');
   359	  var successNickname = document.getElementById('success-nickname');
   360	
   361	  var EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
   362	  var NICKNAME_PATTERN = /^[A-Za-z0-9가-힣]{2,12}$/;
   363	
   364	  var passwordRules = [
   365	    { id: 'rule-length', test: function (v) { return v.length >= 10; } },
   366	    { id: 'rule-letter', test: function (v) { return /[A-Za-z]/.test(v); } },
   367	    { id: 'rule-digit',  test: function (v) { return /[0-9]/.test(v); } },
   368	    { id: 'rule-symbol', test: function (v) { return /[^A-Za-z0-9\s]/.test(v); } }
   369	  ];
   370	
   371	  /* Errors are only shown for fields the user has left at least once (R2). */
   372	  var touched = { email: false, password: false, confirm: false, nickname: false };
   373	
   374	  function isEmailValid() { return EMAIL_PATTERN.test(emailInput.value); }
   375	
   376	  function isPasswordValid() {
   377	    return passwordRules.every(function (rule) { return rule.test(passwordInput.value); });
   378	  }
   379	
   380	  function isConfirmValid() {
   381	    return confirmInput.value.length > 0 && confirmInput.value === passwordInput.value;
   382	  }
   383	
   384	  function isNicknameValid() { return NICKNAME_PATTERN.test(nicknameInput.value); }
   385	
   386	  function isFormValid() {
   387	    return isEmailValid() && isPasswordValid() && isConfirmValid() &&
   388	           isNicknameValid() && termsInput.checked;
   389	  }
   390	
   391	  function setFieldError(input, errorElement, message) {
   392	    if (errorElement.textContent !== message) errorElement.textContent = message;
   393	    if (message) {
   394	      input.setAttribute('aria-invalid', 'true');
   395	    } else {
   396	      input.removeAttribute('aria-invalid');
   397	    }
   398	  }
   399	
   400	  function refreshEmailError() {
   401	    if (!touched.email) return;
   402	    if (emailInput.value === '') {
   403	      setFieldError(emailInput, emailError, 'Email is required.');
   404	    } else if (!isEmailValid()) {
   405	      setFieldError(emailInput, emailError, 'Enter a valid email address.');
   406	    } else {
   407	      setFieldError(emailInput, emailError, '');
   408	    }
   409	  }
   410	
   411	  function refreshPasswordChecklist() {
   412	    passwordRules.forEach(function (rule) {
   413	      var item = document.getElementById(rule.id);
   414	      var met = rule.test(passwordInput.value);
   415	      item.setAttribute('data-met', met ? 'true' : 'false');
   416	      item.querySelector('.tick').textContent = met ? '✓' : '•';
   417	      item.querySelector('.rule-state').textContent = met ? '(rule met)' : '(rule not met)';
   418	    });
   419	  }
   420	
   421	  function refreshPasswordError() {
   422	    if (!touched.password) return;
   423	    if (passwordInput.value === '') {
   424	      setFieldError(passwordInput, passwordError, 'Password is required.');
   425	    } else if (!isPasswordValid()) {
   426	      setFieldError(passwordInput, passwordError, 'Password does not meet all the rules.');
   427	    } else {
   428	      setFieldError(passwordInput, passwordError, '');
   429	    }
   430	  }
   431	
   432	  function refreshConfirmError() {
   433	    if (!touched.confirm) return;
   434	    if (isConfirmValid()) {
   435	      setFieldError(confirmInput, confirmError, '');
   436	    } else if (confirmInput.value === '') {
   437	      setFieldError(confirmInput, confirmError, 'Please confirm your password.');
   438	    } else {
   439	      setFieldError(confirmInput, confirmError, 'Passwords do not match.');
   440	    }
   441	  }
   442	
   443	  function refreshNicknameError() {
   444	    if (!touched.nickname) return;
   445	    var value = nicknameInput.value;
   446	    if (value === '') {
   447	      setFieldError(nicknameInput, nicknameError, 'Nickname is required.');
   448	    } else if (value.length < 2 || value.length > 12) {
   449	      setFieldError(nicknameInput, nicknameError, 'Nickname must be 2–12 characters.');
   450	    } else if (!isNicknameValid()) {
   451	      setFieldError(nicknameInput, nicknameError, 'Use letters, numbers, or Korean only.');
   452	    } else {
   453	      setFieldError(nicknameInput, nicknameError, '');
   454	    }
   455	  }
   456	
   457	  function refreshSubmitState() {
   458	    submitButton.disabled = !isFormValid();
   459	  }
   460	
   461	  emailInput.addEventListener('input', function () {
   462	    refreshEmailError();
   463	    refreshSubmitState();
   464	  });
   465	  emailInput.addEventListener('blur', function () {
   466	    touched.email = true;
   467	    refreshEmailError();
   468	  });
   469	
   470	  passwordInput.addEventListener('input', function () {
   471	    refreshPasswordChecklist();
   472	    refreshPasswordError();
   473	    refreshConfirmError(); /* keep the match error live when password changes (R4) */
   474	    refreshSubmitState();
   475	  });
   476	  passwordInput.addEventListener('blur', function () {
   477	    touched.password = true;
   478	    refreshPasswordError();
   479	  });
   480	
   481	  confirmInput.addEventListener('input', function () {
   482	    refreshConfirmError(); /* clears as soon as the values match (R4) */
   483	    refreshSubmitState();
   484	  });
   485	  confirmInput.addEventListener('blur', function () {
   486	    touched.confirm = true;
   487	    refreshConfirmError();
   488	  });
   489	
   490	  nicknameInput.addEventListener('input', function () {
   491	    refreshNicknameError();
   492	    refreshSubmitState();
   493	  });
   494	  nicknameInput.addEventListener('blur', function () {
   495	    touched.nickname = true;
   496	    refreshNicknameError();
   497	  });
   498	
   499	  termsInput.addEventListener('change', refreshSubmitState);
   500	
   501	  form.addEventListener('submit', function (event) {
   502	    event.preventDefault();
   503	    if (!isFormValid()) return;
   504	    successEmail.textContent = emailInput.value;
   505	    successNickname.textContent = nicknameInput.value;
   506	    form.hidden = true;
   507	    successPanel.hidden = false;
   508	    successPanel.focus();
   509	  });
   510	
   511	  refreshPasswordChecklist();
   512	  refreshSubmitState();
   513	})();
   514	</script>
   515	</body>
   516	</html>

