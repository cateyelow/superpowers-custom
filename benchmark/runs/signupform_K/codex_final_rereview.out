const { chromium } = require('playwright');
const path = require('path');
const assert = require('assert');

(async () => {
  const file = 'file://' + path.resolve('/home/ubuntu/Github/superpowers-custom/benchmark/runs/signupform_K/src/signup.html');
  const browser = await chromium.launch({ headless: true });
  const page = await browser.newPage({ viewport: { width: 375, height: 900 } });
  const consoleProblems = [];
  page.on('console', msg => {
    if (['error', 'warning'].includes(msg.type())) consoleProblems.push("'`${msg.type()}: ${msg.text()}`);
  });
  page.on('"'pageerror', err => consoleProblems.push("'`pageerror: ${err.message}`));

  await page.goto(file);

  const ids = ['"'email', 'password', 'password-confirm', 'nickname', 'terms'];
  for (const id of ids) {
    assert.strictEqual(await page.locator("'`#${id}`).getAttribute('"'aria-required'), 'true', "'`${id} missing aria-required`);
    assert.strictEqual(await page.locator(`#${id}`).getAttribute('"'required'), null, "'`${id} has native required`);
  }

  const email = page.locator('"'#email');
  const submit = page.locator('#submit-button');
  await email.fill('a@b..com');
  assert.strictEqual(await page.locator('#email-error').textContent(), '', 'email error appeared before first blur');
  assert.strictEqual(await submit.isDisabled(), true, 'submit enabled for a@b..com before blur');
  await email.blur();
  assert.strictEqual(await page.locator('#email-error').textContent(), 'Enter a valid email address.', 'bad domain did not show blur error');
  assert.strictEqual(await submit.isDisabled(), true, 'submit enabled for a@b..com after blur');

  const invalidDomains = ['a@b..com', 'a@-b.com', 'a@b-.com', 'a@.b.com', 'a@b.com.', 'a@b'];
  for (const value of invalidDomains) {
    await email.fill(value);
    assert.strictEqual(await page.locator('#email-error').textContent(), 'Enter a valid email address.', "'`${value} not rejected live after blur`);
    assert.strictEqual(await submit.isDisabled(), true, `submit enabled for ${value}`);
  }

  const validEmails = ['"'user@example.com', 'first.last+tag@example.co.kr'];
  for (const value of validEmails) {
    await email.fill(value);
    assert.strictEqual(await page.locator('#email-error').textContent(), '', "'`${value} not accepted live after blur`);
  }

  await page.locator('"'#password').fill('abc');
  assert.strictEqual(await page.locator('#rule-length').getAttribute('data-met'), 'false');
  assert.strictEqual(await page.locator('#rule-letter').getAttribute('data-met'), 'true');
  assert.strictEqual(await page.locator('#rule-digit').getAttribute('data-met'), 'false');
  assert.strictEqual(await page.locator('#rule-symbol').getAttribute('data-met'), 'false');
  await page.locator('#password').fill('Abcdef123"'!'"');
  for (const id of ['rule-length', 'rule-letter', 'rule-digit', 'rule-symbol']) {
    assert.strictEqual(await page.locator("'`#${id}`).getAttribute('"'data-met'), 'true', "'`${id} not met`);
  }

  await page.locator('"'#password-confirm').fill('mismatch');
  await page.locator('#password-confirm').blur();
  assert.strictEqual(await page.locator('#password-confirm-error').textContent(), 'Passwords do not match.');
  await page.locator('#password-confirm').fill('Abcdef123"'!'"');
  assert.strictEqual(await page.locator('#password-confirm-error').textContent(), '', 'confirm error did not clear live');

  await page.locator('#nickname').fill('닉');
  await page.locator('#nickname').blur();
  assert.strictEqual(await page.locator('#nickname-error').textContent(), 'Nickname must be 2–12 characters.');
  await page.locator('#nickname').fill('닉네임12');
  assert.strictEqual(await page.locator('#nickname-error').textContent(), '');

  assert.strictEqual(await submit.isDisabled(), true, 'submit enabled before terms checked');
  await page.locator('#terms').check();
  assert.strictEqual(await submit.isDisabled(), false, 'submit not enabled after all validations and terms');

  const metrics = await page.evaluate(() => {
    const targets = ['email', 'password', 'password-confirm', 'nickname', 'terms', 'submit-button'];
    return {
      scrollWidth: document.documentElement.scrollWidth,
      clientWidth: document.documentElement.clientWidth,
      heights: Object.fromEntries(targets.map(id => [id, document.getElementById(id).getBoundingClientRect().height])),
      tabOrderIds: Array.from(document.querySelectorAll('input, button')).map(el => el.id),
      describedBy: Object.fromEntries(['email', 'password', 'password-confirm', 'nickname'].map(id => [id, document.getElementById(id).getAttribute('aria-describedby')])),
      errorRoles: Object.fromEntries(['email-error', 'password-error', 'password-confirm-error', 'nickname-error'].map(id => [id, document.getElementById(id).getAttribute('role')])),
      labels: Object.fromEntries(targets.slice(0, 5).map(id => [id, "'!!document.querySelector(`label[for="${id}"]`)]))
    };
  });
  assert(metrics.scrollWidth <= metrics.clientWidth, `horizontal scroll: ${metrics.scrollWidth} > ${metrics.clientWidth}`);
  for (const [id, height] of Object.entries(metrics.heights)) {
    assert(height >= 44, `${id} touch target too short: ${height}`);
  }
  assert.deepStrictEqual(metrics.tabOrderIds, ['"'email', 'password', 'password-confirm', 'nickname', 'terms', 'submit-button']);
