   189	<body>
   190	<main class="container">
   191	  <h1>Create your account</h1>
   192	
   193	  <!-- novalidate: the page's own validators drive all messaging; native
   194	       browser bubbles would conflict with the custom error UI. -->
   195	  <form id="signup-form" novalidate>
   196	    <div class="field">
   197	      <label for="email">Email</label>
   198	      <input id="email" name="email" type="email" autocomplete="email"
   199	             aria-describedby="email-error" required>
   200	      <p class="error" id="email-error" role="alert"></p>
   201	    </div>
   202	
   203	    <div class="field">
   204	      <label for="password">Password</label>
   205	      <input id="password" name="password" type="password" autocomplete="new-password"
   206	             aria-describedby="password-rules" required>
   207	      <ul class="rules" id="password-rules">
   208	        <li id="rule-length">
   209	          <span class="rule-icon" aria-hidden="true">✗</span>
   210	          <span>At least 10 characters</span>
   211	          <span class="visually-hidden rule-state"> (not met)</span>
   212	        </li>
   213	        <li id="rule-letter-digit">
   214	          <span class="rule-icon" aria-hidden="true">✗</span>
   215	          <span>At least one letter and one digit</span>
   216	          <span class="visually-hidden rule-state"> (not met)</span>
   217	        </li>
   218	        <li id="rule-symbol">
   219	          <span class="rule-icon" aria-hidden="true">✗</span>
   220	          <span>At least one symbol</span>
   221	          <span class="visually-hidden rule-state"> (not met)</span>
   222	        </li>
   223	      </ul>
   224	    </div>
   225	
   226	    <div class="field">
   227	      <label for="password-confirm">Confirm password</label>
   228	      <input id="password-confirm" name="password-confirm" type="password"
   229	             autocomplete="new-password" aria-describedby="password-confirm-error" required>
   230	      <p class="error" id="password-confirm-error" role="alert"></p>
   231	    </div>
   232	
   233	    <div class="field">
   234	      <label for="nickname">Nickname</label>
   235	      <input id="nickname" name="nickname" type="text" autocomplete="nickname"
   236	             aria-describedby="nickname-hint nickname-error" required>
   237	      <p class="hint" id="nickname-hint">2–12 characters: letters, digits, or Korean.</p>
   238	      <p class="error" id="nickname-error" role="alert"></p>
   239	    </div>
   240	
   241	    <div class="field-checkbox">
   242	      <input id="terms" name="terms" type="checkbox">
   243	      <label for="terms">I agree to the Terms of Service</label>
   244	    </div>
   245	
   246	    <button type="submit" id="submit-btn" disabled>Create account</button>
   247	  </form>
   248	
   249	  <!-- Success panel: hidden until submit; tabindex="-1" so it can receive
   250	       programmatic keyboard focus (R7). The password is never shown here. -->
   251	  <section id="success-panel" class="success" tabindex="-1" hidden
   252	           aria-labelledby="success-title">
   253	    <h2 id="success-title">Account created</h2>
   254	    <p>Welcome! Your signup was successful.</p>
   255	    <dl>
   256	      <dt>Email</dt>
   257	      <dd id="success-email"></dd>
   258	      <dt>Nickname</dt>
   259	      <dd id="success-nickname"></dd>
   260	    </dl>
   261	  </section>
   262	</main>
   263	
   264	<script>
   265	(function () {
   266	  'use strict';
   267	
   268	  /*
   269	   * Behavior model
   270	   * --------------
   271	   * - Validation logic lives in pure validator functions; every event path
   272	   *   (input, blur, submit) goes through the same getValidationState() ->
   273	   *   render() pipeline, so there is exactly one source of truth and no
   274	   *   duplicated per-event validation.
   275	   * - First-blur gating: a field's error message is only *displayed* once
   276	   *   the field has been blurred at least once (`touched`). After that
   277	   *   first blur, every input event re-renders, so corrections clear the
   278	   *   error live. The password checklist is exempt: it is live from the
   279	   *   first keystroke by design (R3).
   280	   * - The submit button uses the native `disabled` attribute, recomputed on
   281	   *   every event, so an invalid form can never be submitted (R6).
   282	   */
   283	
   284	  // --- Element references -------------------------------------------------
   285	
   286	  var form = document.getElementById('signup-form');
   287	  var emailInput = document.getElementById('email');
   288	  var passwordInput = document.getElementById('password');
   289	  var confirmInput = document.getElementById('password-confirm');
   290	  var nicknameInput = document.getElementById('nickname');
   291	  var termsInput = document.getElementById('terms');
   292	  var submitBtn = document.getElementById('submit-btn');
   293	
   294	  var emailErrorEl = document.getElementById('email-error');
   295	  var confirmErrorEl = document.getElementById('password-confirm-error');
   296	  var nicknameErrorEl = document.getElementById('nickname-error');
   297	
   298	  var ruleLengthEl = document.getElementById('rule-length');
   299	  var ruleLetterDigitEl = document.getElementById('rule-letter-digit');
   300	  var ruleSymbolEl = document.getElementById('rule-symbol');
   301	
   302	  var successPanel = document.getElementById('success-panel');
   303	  var successEmailEl = document.getElementById('success-email');
   304	  var successNicknameEl = document.getElementById('success-nickname');
   305	
   306	  // Which fields have been blurred at least once (first-blur gating, R2/R4/R5).
   307	  var touched = { email: false, password: false, confirm: false, nickname: false };
   308	
   309	  // --- Validators (pure functions; return '' when valid) -------------------
   310	
   311	  // Pragmatic email check: non-space local part, "@", non-space domain
   312	  // containing at least one dot (rejects "a@b", accepts "a@b.co").
   313	  var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
   314	
   315	  // Nickname: 2–12 chars of Latin letters, digits, or Korean. Choice
   316	  // documented per spec: complete Hangul syllables (가-힣) AND standalone
   317	  // jamo (ㄱ-ㅎ consonants, ㅏ-ㅣ vowels) are all accepted; anything else
   318	  // (spaces, symbols, other scripts) is rejected.
   319	  var NICKNAME_RE = /^[A-Za-z0-9가-힣ㄱ-ㅎㅏ-ㅣ]{2,12}$/;
   320	
   321	  // Atomic password conditions. All FOUR must hold for the password to be
   322	  // valid; the visible checklist merges hasLetter+hasDigit into one item
   323	  // but validity still requires each condition individually (R3).
   324	  // "Symbol" = any character that is not a letter, digit, or whitespace.
   325	  function getPasswordChecks(pw) {
   326	    return {
   327	      minLength: pw.length >= 10,
   328	      hasLetter: /[A-Za-z]/.test(pw),
   329	      hasDigit: /[0-9]/.test(pw),
   330	      hasSymbol: /[^A-Za-z0-9\s]/.test(pw)
   331	    };
   332	  }
   333	
   334	  function validateEmail(value) {
   335	    if (value === '') return 'Email is required.';
   336	    return EMAIL_RE.test(value) ? '' : 'Enter a valid email address.';
   337	  }
   338	
   339	  // Returns a message for consistency with the other validators; the
   340	  // password field communicates specifics through the checklist instead
   341	  // of an error slot, so the text itself is only used as a truthy flag.
   342	  function validatePassword(value) {
   343	    var c = getPasswordChecks(value);
   344	    var valid = c.minLength && c.hasLetter && c.hasDigit && c.hasSymbol;
   345	    return valid ? '' : 'Password does not meet all requirements.';
   346	  }
   347	
   348	  function validateConfirm(password, confirm) {
   349	    if (confirm === '') return 'Please re-enter your password.';
   350	    return confirm === password ? '' : 'Passwords do not match.';
   351	  }
   352	
   353	  function validateNickname(value) {
   354	    if (value === '') return 'Nickname is required.';
   355	    return NICKNAME_RE.test(value) ? '' : '2–12 letters, digits, or Korean only.';
   356	  }
   357	
   358	  // --- Single source of truth ----------------------------------------------
   359	
   360	  function getValidationState() {
   361	    var emailError = validateEmail(emailInput.value);
   362	    var passwordError = validatePassword(passwordInput.value);
   363	    var confirmError = validateConfirm(passwordInput.value, confirmInput.value);
   364	    var nicknameError = validateNickname(nicknameInput.value);
   365	    var termsChecked = termsInput.checked;
   366	    return {
   367	      checks: getPasswordChecks(passwordInput.value),
   368	      emailError: emailError,
   369	      passwordError: passwordError,
   370	      confirmError: confirmError,
   371	      nicknameError: nicknameError,
   372	      termsChecked: termsChecked,
   373	      formValid: !emailError && !passwordError && !confirmError &&
   374	                 !nicknameError && termsChecked
   375	    };
   376	  }
   377	
   378	  // --- Rendering ------------------------------------------------------------
   379	
   380	  // Shows/clears one field's error message and aria-invalid flag.
   381	  // `show` implements the first-blur gate: until the field is touched the
   382	  // message stays hidden even if the value is invalid.
   383	  function renderFieldError(input, errorEl, message, show) {
   384	    var hasError = show && message !== '';
   385	    errorEl.textContent = hasError ? message : '';
   386	    if (hasError) {
   387	      input.setAttribute('aria-invalid', 'true');
   388	    } else {
   389	      input.removeAttribute('aria-invalid');
   390	    }
   391	  }
   392	
   393	  function renderRule(li, met) {
   394	    li.classList.toggle('met', met);
   395	    li.querySelector('.rule-icon').textContent = met ? '✓' : '✗';
   396	    li.querySelector('.rule-state').textContent = met ? ' (met)' : ' (not met)';
   397	  }
   398	
   399	  function render() {
   400	    var s = getValidationState();
   401	
   402	    renderFieldError(emailInput, emailErrorEl, s.emailError, touched.email);
   403	    renderFieldError(confirmInput, confirmErrorEl, s.confirmError, touched.confirm);
   404	    renderFieldError(nicknameInput, nicknameErrorEl, s.nicknameError, touched.nickname);
   405	
   406	    // Checklist is live from the first keystroke (no touch gating).
   407	    renderRule(ruleLengthEl, s.checks.minLength);
   408	    renderRule(ruleLetterDigitEl, s.checks.hasLetter && s.checks.hasDigit);
   409	    renderRule(ruleSymbolEl, s.checks.hasSymbol);
   410	
   411	    // Password has no error slot (the checklist plays that role), but it
   412	    // still flags aria-invalid once blurred while unmet.
   413	    if (touched.password && s.passwordError) {
   414	      passwordInput.setAttribute('aria-invalid', 'true');
   415	    } else {
   416	      passwordInput.removeAttribute('aria-invalid');
   417	    }
   418	
   419	    submitBtn.disabled = !s.formValid;
   420	  }
   421	
   422	  // --- Events ----------------------------------------------------------------
   423	
   424	  function markTouched(key) {
   425	    return function () {
   426	      touched[key] = true;
   427	      render();
   428	    };
   429	  }
   430	
   431	  // `input` covers typing, paste, and IME (Korean) composition updates.
   432	  // Re-rendering everything on any event is what makes cross-field rules
   433	  // (e.g. confirm mismatch clearing while typing in the *password* field)
   434	  // work without special cases.
   435	  emailInput.addEventListener('input', render);
   436	  passwordInput.addEventListener('input', render);
   437	  confirmInput.addEventListener('input', render);
   438	  nicknameInput.addEventListener('input', render);
   439	  termsInput.addEventListener('change', render);
   440	
   441	  emailInput.addEventListener('blur', markTouched('email'));
   442	  passwordInput.addEventListener('blur', markTouched('password'));
   443	  confirmInput.addEventListener('blur', markTouched('confirm'));
   444	  nicknameInput.addEventListener('blur', markTouched('nickname'));
   445	
   446	  form.addEventListener('submit', function (event) {
   447	    // Never navigate: the page works from file:// with no server (R7).
   448	    event.preventDefault();
   449	
   450	    // Belt and braces: the button is disabled while invalid, but re-check
   451	    // through the same single validation pipeline anyway.
   452	    if (!getValidationState().formValid) return;
   453	
   454	    // textContent (never innerHTML) so typed values are inert.
   455	    successEmailEl.textContent = emailInput.value;
   456	    successNicknameEl.textContent = nicknameInput.value;
   457	
   458	    form.hidden = true;
   459	    successPanel.hidden = false;
   460	    // Move keyboard focus to the panel so screen readers and keyboard
   461	    // users land on the confirmation (R7).
   462	    successPanel.focus();
   463	  });
   464	
   465	  // Initial paint (button starts disabled, checklist starts all-unmet).
   466	  render();
   467	})();
   468	</script>
   469	</body>
   470	</html>

