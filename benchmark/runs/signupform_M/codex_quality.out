/bin/bash -lc "node <<'NODE'
const { chromium } = require('playwright');
const path = require('path');
const assert = require('assert');

(async () => {
  const browser = await chromium.launch({ headless: true });
  const page = await browser.newPage({ viewport: { width: 375, height: 812 } });
  const requests = [];
  page.on('request', req => requests.push(req.url()));
  const fileUrl = 'file://' + path.resolve('src/signup.html');
  await page.goto(fileUrl);

  await assert.rejects(page.locator('#success-panel').innerText({ timeout: 100 }), /Timeout|waiting/).catch(() => {});
  assert.strictEqual(await page.locator('#submit-btn').isDisabled(), true, 'submit initially disabled');

  await page.locator('#email').fill('bad');
  assert.strictEqual(await page.locator('#email-error').innerText(), '', 'email error hidden before blur');
  await page.locator('#email').blur();
  assert.match(await page.locator('#email-error').innerText(), /valid email/i, 'email error after blur');
  await page.locator('#email').fill('user@example.com');
  assert.strictEqual(await page.locator('#email-error').innerText(), '', 'email clears live');

  await page.locator('#password').fill('abcdefghi1');
  assert.strictEqual(await page.locator('#rule-length').evaluate(el => el.classList.contains('met')), true, 'length rule met');
  assert.strictEqual(await page.locator('#rule-letter-digit').evaluate(el => el.classList.contains('met')), true, 'letter+digit rule met');
  assert.strictEqual(await page.locator('#rule-symbol').evaluate(el => el.classList.contains('met')), false, 'symbol rule unmet');
  await page.locator('#password').fill('abcdefghi1"'!'"');
  assert.strictEqual(await page.locator('#rule-symbol').evaluate(el => el.classList.contains('met')), true, 'symbol rule met');

  await page.locator('#password-confirm').fill('wrong');
  await page.locator('#password-confirm').blur();
  assert.match(await page.locator('#password-confirm-error').innerText(), /do not match/i, 'confirm mismatch after blur');
  await page.locator('#password-confirm').fill('abcdefghi1"'!'"');
  assert.strictEqual(await page.locator('#password-confirm-error').innerText(), '', 'confirm clears live');

  await page.locator('#nickname').fill('a');
  await page.locator('#nickname').blur();
  assert.match(await page.locator('#nickname-error').innerText(), /2.*12/i, 'nickname invalid after blur');
  await page.locator('#nickname').fill('홍길동2');
  assert.strictEqual(await page.locator('#nickname-error').innerText(), '', 'nickname clears live');

  assert.strictEqual(await page.locator('#submit-btn').isDisabled(), true, 'submit disabled before terms');
  await page.locator('#terms').check();
  assert.strictEqual(await page.locator('#submit-btn').isEnabled(), true, 'submit enabled when valid');
  await page.locator('#submit-btn').click();
  assert.strictEqual(await page.locator('#signup-form').isHidden(), true, 'form hidden after submit');
  assert.strictEqual(await page.locator('#success-panel').isVisible(), true, 'success visible after submit');
  assert.strictEqual(await page.locator('#success-email').innerText(), 'user@example.com', 'success email shown');
  assert.strictEqual(await page.locator('#success-nickname').innerText(), '홍길동2', 'success nickname shown');
  assert.strictEqual(await page.evaluate(() => document.activeElement.id), 'success-panel', 'focus moved to success panel');

  const nonFileRequests = requests.filter(url => "'!url.startsWith('"'file://'));
  assert.deepStrictEqual(nonFileRequests, [], 'no external requests');
  await browser.close();
  console.log('playwright smoke: PASS');
  console.log('checked: file:// load, gated email, password rules, confirm, nickname, disabled submit, success focus, no external requests');
})().catch(async err => {
  console.error('playwright smoke: FAIL');
  console.error(err && err.stack || err);
  process.exit(1);
});
