     4	// logic itself lives in the pure parser module).
     5	
     6	import { readFile, writeFile, rename, unlink } from 'node:fs/promises';
     7	import { dirname, join, basename } from 'node:path';
     8	import process from 'node:process';
     9	import { parseCsv, HeaderError } from './parser.js';
    10	
    11	const USAGE = `Usage: node src/importCsv.js <input.csv> <output.json>
    12	
    13	Imports a contacts CSV (header: name,email,phone, any order) into a
    14	normalized JSON file: { "contacts": [ { "name", "email", "phone" }, ... ] }.
    15	
    16	Invalid rows are skipped and reported on stderr; the run still succeeds
    17	unless the input is unreadable, the header is missing a required column,
    18	or the output can't be written.
    19	
    20	Options:
    21	  -h, --help    Show this help message and exit
    22	`;
    23	
    24	async function writeAtomic(outputPath, data) {
    25	  const dir = dirname(outputPath) || '.';
    26	  const tempPath = join(dir, `.${basename(outputPath)}.tmp-${process.pid}-${Date.now()}`);
    27	  try {
    28	    await writeFile(tempPath, data, 'utf8');
    29	    await rename(tempPath, outputPath);
    30	  } catch (err) {
    31	    await unlink(tempPath).catch(() => {});
    32	    throw err;
    33	  }
    34	}
    35	
    36	async function main(argv) {
    37	  if (argv.includes('--help') || argv.includes('-h')) {
    38	    process.stdout.write(USAGE);
    39	    return 0;
    40	  }
    41	
    42	  if (argv.length !== 2) {
    43	    process.stderr.write(USAGE);
    44	    return 2;
    45	  }
    46	
    47	  const [inputPath, outputPath] = argv;
    48	
    49	  let content;
    50	  try {
    51	    content = await readFile(inputPath, 'utf8');
    52	  } catch (err) {
    53	    process.stderr.write(`error: cannot read input file '${inputPath}': ${err.message}\n`);
    54	    return 2;
    55	  }
    56	
    57	  let result;
    58	  try {
    59	    result = parseCsv(content);
    60	  } catch (err) {
    61	    if (err instanceof HeaderError) {
    62	      process.stderr.write(`error: ${err.message}\n`);
    63	      return 2;
    64	    }
    65	    throw err;
    66	  }
    67	
    68	  const { contacts, errors } = result;
    69	  const total = contacts.length + errors.length;
    70	  const outputJson = `${JSON.stringify({ contacts }, null, 2)}\n`;
    71	
    72	  try {
    73	    await writeAtomic(outputPath, outputJson);
    74	  } catch (err) {
    75	    process.stderr.write(`error: cannot write output file '${outputPath}': ${err.message}\n`);
    76	    return 2;
    77	  }
    78	
    79	  for (const { line, reason } of errors) {
    80	    process.stderr.write(`line ${line}: ${reason}\n`);
    81	  }
    82	  process.stdout.write(`imported ${contacts.length}/${total} rows\n`);
    83	
    84	  return errors.length > 0 ? 1 : 0;
